# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Groq API key (free) from https://console.groq.com
GROQ_API_KEY=

# Async PostgreSQL DSN. Local example:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/reminders
# On Railway use the provided DATABASE_URL (driver is auto-normalized to asyncpg).
DATABASE_URL=

# Public HTTPS URL of the deployed WebApp (Telegram WebApp button target).
# Example: https://your-webapp.up.railway.app
WEBAPP_URL=

# Optional: host/port for the bundled FastAPI server (defaults below).
API_HOST=0.0.0.0
API_PORT=8000

# Optional: default timezone for newly registered users.
DEFAULT_TIMEZONE=Europe/Berlin
